[Unit]
Description=SSH tunnel to gpu-soroban vLLM (port 8000)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
Environment=AUTOSSH_GATETIME=0
ExecStart=/usr/bin/autossh -M 0 -N -o "ServerAliveInterval=30" -o "ServerAliveCountMax=3" -o "ExitOnForwardFailure=yes" -L 127.0.0.1:8000:localhost:8000 gpu-soroban
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
